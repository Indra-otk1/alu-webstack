global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend http_front
    bind *:80
    default_backend http_back

frontend https_front
    bind *:443 ssl crt /etc/haproxy/certs/elvistanguy.tech.pem
    default_backend http_back

backend http_back
    balance roundrobin
    server web-01 18.212.192.18:80 check
    server web-02 52.90.174.46:80 check
